# =============================================================================
# OpenClaw Telegram Mini App — Example Environment Variables
# =============================================================================
# This fork targets OpenClaw-compatible gateway auth and Telegram Mini App UI.
# Exact gateway auth mode depends on your OpenClaw deployment.
# =============================================================================

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_OWNER_ID=YOUR_USER_ID_HERE
TELEGRAM_ALLOWED_USERS=YOUR_USER_ID_HERE

# Bridge listen address
MINIAPP_HOST=127.0.0.1
MINIAPP_PORT=8765

# Public HTTPS origin used by diagnostics and deployment checks
MINIAPP_PUBLIC_ORIGIN=https://miniapp.example.com

# Shared-secret auth for the OpenClaw gateway HTTP surface.
# Depending on your deployment this may be gateway.auth.token or password-mode secret.
OPENCLAW_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN_HERE
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# Browser fallback session controls
MINIAPP_BROWSER_SESSION_TTL_SECONDS=1800
MINIAPP_RATE_LIMIT_WINDOW_SECONDS=60
MINIAPP_RATE_LIMIT_MAX_REQUESTS=180
MINIAPP_RATE_LIMIT_ACTION_MAX_REQUESTS=12

# Logging / diagnostics
MINIAPP_AUTH_DEBUG=false
MINIAPP_BRIDGE_LOG_PATH=$HOME/.openclaw/logs/openclaw-miniapp-bridge.log
MINIAPP_BRIDGE_ERR_LOG_PATH=$HOME/.openclaw/logs/openclaw-miniapp-bridge.err.log
